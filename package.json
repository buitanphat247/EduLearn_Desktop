{
  "name": "edulearn-desktop",
  "version": "1.0.0",
  "description": "Electron shell for EduLearn Next.js client",
  "main": "src/main.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "desktop": "node scripts/open-electron.js",
    "desktop:stable": "node scripts/open-electron.js --no-reload",
    "desktop:protected": "node scripts/open-protected-electron.js",
    "integrity:manifest": "node scripts/generate-integrity-manifest.js --root .",
    "build:preload": "esbuild src/preload.js --bundle --platform=node --format=cjs --external:electron --outfile=dist/preload.js",
    "package": "npm run build:preload && npm run integrity:manifest && electron-builder --config electron-builder.yml",
    "core:build": "cargo build --manifest-path rust-core/Cargo.toml --release",
    "bootstrapper:build": "cargo build --manifest-path bootstrapper/Cargo.toml --release",
    "bootstrapper:test": "cargo test --manifest-path bootstrapper/Cargo.toml",
    "desktop-isolation:build": "cargo build --manifest-path desktop-isolation-prototype/Cargo.toml --release",
    "desktop-isolation:test": "cargo test --manifest-path desktop-isolation-prototype/Cargo.toml",
    "service:build": "cargo build --manifest-path edulearn-exam-service/Cargo.toml --release",
    "service:test": "cargo test --manifest-path edulearn-exam-service/Cargo.toml",
    "service:trusted-key": "node edulearn-exam-service/derive-trusted-key.mjs",
    "test": "node --test .\\test\\*.test.js",
    "test:ipc": "node --test .\\test\\named-pipe.integration.js",
    "test:core": "cargo test --manifest-path rust-core/Cargo.toml",
    "test:all": "npm run test && npm run test:core",
    "test:release": "npm run test && npm run test:core && npm run service:test && npm run bootstrapper:test && npm run desktop-isolation:test && npm run test:ipc && npm test --prefix ..\\client -- app-runtime desktop-core desktop-exam-session exam-security && npm test --prefix ..\\server\\server-nest -- --runInBand test/unit/exam-security/exam-security.service.spec.ts",
    "build:release": "npm run core:build && npm run service:build && npm run bootstrapper:build && npm run desktop-isolation:build && npm run build --prefix ..\\client && npm run build --prefix ..\\server\\server-nest",
    "lint:exam-guard": "node --check .\\src\\core-runtime.js && node --check .\\src\\rust-sidecar.js && node --check .\\native-tests\\release-gate.js && node --check .\\native-tests\\validation-report.js && node --check .\\native-tests\\release-report.js",
    "native:matrix": "powershell -ExecutionPolicy Bypass -File .\\native-tests\\Run-ExamGuardMatrix.ps1",
    "native:etw-smoke": "powershell -ExecutionPolicy Bypass -File .\\native-tests\\Run-EtwProducerSmoke.ps1",
    "native:report": "node .\\native-tests\\validation-report.js --input .\\native-tests\\results --allow-not-tested",
    "native:release-gate": "node .\\native-tests\\validation-report.js --input .\\native-tests\\release-evidence --output .\\native-tests\\results\\validation-report.md",
    "release:verify": "npm run lint:exam-guard && npm run lint:exam-guard --prefix ..\\client && npm run lint:exam-guard --prefix ..\\server\\server-nest && npm run test:release && npm run build:release && npm run native:release-gate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "electron": "^42.4.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "electronmon": "^2.0.4",
    "esbuild": "^0.28.1",
    "wait-on": "^9.0.10"
  },
  "electronmon": {
    "patterns": [
      "!logs/**",
      "!demo/**",
      "!mock/**",
      "!**/*.jsonl"
    ]
  }
}
